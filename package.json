{
  "name": "belote-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "fuser -k 3002/tcp 2>/dev/null; npm run dev --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
